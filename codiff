# use lookbehind/lookahead to obtain: foo(bar) => ['foo','(','bar',')']
my sub tokenise {
  my $s = $_[0];
  if   ($MODE==1) { return split //,$s }
  elsif($MODE==2) { return split /(?<=$REW)|(?=$REW)/,$s }
  elsif($MODE==3) { return split /(?<=$REB)|(?=$REB)/,$s }
