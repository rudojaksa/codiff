  my $w = length(int((-s $file1)/35)); # line-number length (guessed for average line width 35)

  # -B ignore changes where lines are all blank
  my $o = "-u0";
     $o = "-u999999" if $ALL;
     $o = "-u$CONTEXT" if defined $CONTEXT;
     $o.= " -B" if $NOBLANK;
     $o.= " -b" if $ANYSPACE;
     $o.= " -w" if $NOSPACES;
  my $cmd = "diff $o -- \Q$file1\E \Q$file2\E";
